# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# =========================================================================
# Production & Build (Code compilé)
# =========================================================================
/dist
/tmp
/out-tsc
/bazel-out

# =========================================================================
# SÉCURITÉ : Fichiers d'environnement et Secrets (À AJOUTER ABSOLUMENT)
# =========================================================================
# Si tu utilises des fichiers .env côté front
.env
.env.local
.env.*

# Si tu utilises le système d'environnement classique d'Angular :
# On garde 'environment.ts' (la structure de dev) mais on IGNORE les fichiers de prod ou locaux avec les vrais secrets.
**/src/environments/environment.prod.ts
**/src/environments/environment.local.ts
**/src/environments/environment.development.ts

# =========================================================================
# Dépendances Node
# =========================================================================
/node_modules
npm-debug.log
yarn-error.log
.pnpm-debug.log

